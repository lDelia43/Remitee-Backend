# Copy this file to `.env` in the same folder and adjust values as needed:
#   cp .env.example .env

# ── SQL Server ──
MSSQL_SA_PASSWORD=Your_Strong!Passw0rd
MSSQL_PID=Developer
DB_NAME=SweetMedical
# Host port mapped to the SQL Server container (internal port is always 1433)
DB_HOST_PORT=1433

# ── API ──
ASPNETCORE_ENVIRONMENT=Development
# Host port mapped to the API container (internal port is 8080)
API_HOST_PORT=8080
